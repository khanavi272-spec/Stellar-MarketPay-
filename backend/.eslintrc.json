{
  "root": true,
  "env": {
    "node": true,
    "es2022": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "overrides": [
    {
      "files": [
        "src/services/store.js",
        "src/middleware/rateLimiter.js"
      ],
      "parserOptions": {
        "sourceType": "module"
      }
    },
    {
      "files": ["**/*.test.js"],
      "env": {
        "jest": true
      }
    }
  ]
}
